# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=twf_cattle_crm

# Auth & sessions (required)
JWT_SECRET=your_long_random_secret_min_32_chars

# Auth & sessions (optional – defaults shown)
JWT_EXPIRES_IN=1h
SESSION_EXPIRY_HOURS=11

# Server
PORT=5000
WHATSAPP_AUTO_START=true
WHATSAPP_AUTH_PATH=./.wwebjs_auth
# Optional: set chromium path on production server if needed by puppeteer
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# URLs (set for production)
SERVER_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173
PASSWORD_RESET_BASE_URL=http://localhost:5173

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourdomain.com

# Login email branding (optional)
APP_NAME=RGOC ERP

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Microsoft OAuth
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_TENANT=common

# Apple OAuth
APPLE_CLIENT_ID=your-apple-client-id
